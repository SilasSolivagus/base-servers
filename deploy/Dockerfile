# syntax=docker/dockerfile:1
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/base-servers ./cmd/base-servers

FROM gcr.io/distroless/static-debian12
COPY --from=build /out/base-servers /base-servers
EXPOSE 8081
ENTRYPOINT ["/base-servers"]
